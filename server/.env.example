# ─── Database (Railway ໃຫ້ auto) ─────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── JWT (ຕ້ອງ random string 32+ chars) ─────────────────────
JWT_SECRET=replace-with-random-32-char-string-here
JWT_REFRESH_SECRET=replace-with-another-random-32-char-string

JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CORS (Railway URL ຂອງທ່ານ) ─────────────────────────────
ALLOWED_ORIGINS=https://your-app.railway.app

# ─── Rate Limit ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20

# ─── Invoice ────────────────────────────────────────────────
INVOICE_MATCH_TOLERANCE_PERCENT=5
