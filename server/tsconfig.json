{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",

    "lib": ["ES2022"],

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "baseUrl": ".",
    "ignoreDeprecations": "6.0",

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": [
    "src/**/*",
    "prisma/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}